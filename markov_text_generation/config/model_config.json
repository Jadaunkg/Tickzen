{
  "model_settings": {
    "default_order": 2,
    "temperature": 0.7,
    "min_training_samples": 10,
    "validation_split": 0.1
  },
  
  "section_configs": {
    "introduction": {
      "min_length": 50,
      "max_length": 150,
      "temperature": 0.7,
      "preserve_patterns": ["{TICKER}", "{COMPANY}", "{PRICE}", "{CHANGE}", "{SENTIMENT}"]
    },
    
    "technical_analysis": {
      "min_length": 80,
      "max_length": 200,
      "temperature": 0.6,
      "preserve_patterns": ["{TICKER}", "{RSI}", "{MACD}", "{SMA50}", "{SMA200}", "{SUPPORT}", "{RESISTANCE}"]
    },
    
    "fundamental_analysis": {
      "min_length": 80,
      "max_length": 200,
      "temperature": 0.65,
      "preserve_patterns": ["{TICKER}", "{PE}", "{PEG}", "{DEBT_EQUITY}", "{ROE}", "{PROFIT_MARGIN}", "{REVENUE_GROWTH}"]
    },
    
    "valuation": {
      "min_length": 60,
      "max_length": 150,
      "temperature": 0.7,
      "preserve_patterns": ["{TICKER}", "{FAIR_VALUE}", "{CURRENT_PRICE}", "{UPSIDE}", "{TARGET}", "{RATING}"]
    },
    
    "conclusion": {
      "min_length": 50,
      "max_length": 120,
      "temperature": 0.75,
      "preserve_patterns": ["{TICKER}", "{RATING}", "{KEY_POINT_1}", "{KEY_POINT_2}", "{KEY_POINT_3}"]
    }
  },
  
  "data_processing": {
    "min_words_per_section": 50,
    "max_words_per_section": 500,
    "remove_duplicates": true,
    "normalize_placeholders": true,
    "quality_threshold": 0.3
  },
  
  "training": {
    "batch_size": 100,
    "auto_save_interval": 50,
    "enable_validation": true,
    "validation_samples": 10,
    "min_validation_score": 50.0
  },
  
  "paths": {
    "base_dir": "markov_text_generation",
    "models_dir": "markov_text_generation/models",
    "raw_data_dir": "markov_text_generation/training_data/raw",
    "processed_data_dir": "markov_text_generation/training_data/processed",
    "templates_dir": "markov_text_generation/templates",
    "backup_dir": "markov_text_generation/backups"
  },
  
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "markov_text_generation/logs/markov_system.log"
  },
  
  "performance": {
    "cache_models": true,
    "max_cached_models": 10,
    "lazy_load": true,
    "parallel_generation": false
  }
}
